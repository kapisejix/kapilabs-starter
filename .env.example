# Site URL (used for JSON-LD structured data and canonical URLs)
SITE_URL=https://yourdomain.com

# KapiLabs CMS Backend
# Options: sanity | emdash | wordpress | contentful
PUBLIC_CMS_BACKEND=sanity

# Sanity
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_TOKEN=

# EmDash
EMDASH_API_URL=http://localhost:3000/api

# WordPress Headless
WORDPRESS_API_URL=https://yourdomain.com/wp-json/wp/v2

# Contentful
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# Forms / Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FORM_EMAIL_TO=
FORM_EMAIL_FROM=

# Admin
FORM_ADMIN_KEY=change-this-secret-key

# Form Storage
FORM_STORAGE_BACKEND=json
