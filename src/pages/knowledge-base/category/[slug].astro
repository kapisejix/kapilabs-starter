---
import SiteLayout from "@kapi/layouts/SiteLayout.astro";
import { getKnowledgeBaseTree, getKnowledgeBaseArticles } from "@kapi/cms";

const { slug } = Astro.params;

const tree = await getKnowledgeBaseTree();
const category = tree.categories.find((c) => c.slug === slug);

const { articles } = await getKnowledgeBaseArticles({
  categorySlug: slug,
  pageSize: 50,
});
---

<SiteLayout
  title={`${category?.title || "Category"} — Knowledge Base`}
  description={category?.description || `Articles in ${category?.title || slug}`}
>
  <main class="kb-category-page site-container">
    <nav aria-label="Breadcrumb" class="kb-breadcrumbs">
      <a href="/knowledge-base">Knowledge Base</a>
      <span class="sep">/</span>
      <span>{category?.title || slug}</span>
    </nav>

    <header class="cat-header">
      <h1>{category?.icon && <span class="cat-icon">{category.icon}</span>} {category?.title || slug}</h1>
      {category?.description && <p>{category.description}</p>}
    </header>

    <div class="cat-layout">
      <aside class="cat-sidebar">
        <nav aria-label="Categories">
          <h3>Categories</h3>
          <ul class="cat-tree">
            {tree.categories.map((cat) => (
              <li class:list={["cat-item", cat.slug === slug && "active"]}>
                <a href={`/knowledge-base/category/${cat.slug}`}>
                  {cat.icon && <span>{cat.icon}</span>}
                  {cat.title} ({cat.articleCount || 0})
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <section class="article-list">
        {articles.length > 0 ? (
          <ul>
            {articles.map((article) => (
              <li class="article-card">
                <a href={`/knowledge-base/${article.slug}`} class="article-link">
                  <h2>{article.title}</h2>
                  {article.excerpt && <p>{article.excerpt}</p>}
                  <div class="article-meta">
                    {article.publishedAt && (
                      <time datetime={article.publishedAt}>
                        {new Date(article.publishedAt).toLocaleDateString()}
                      </time>
                    )}
                    {article.featured && <span class="featured-badge">Featured</span>}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">No articles in this category yet.</p>
        )}
      </section>
    </div>
  </main>
</SiteLayout>

<style>
  .kb-category-page {
    padding: 2rem 0;
  }

  .kb-breadcrumbs {
    font-size: 0.85rem;
    color: var(--color-muted, #6b7280);
    margin-bottom: 1.5rem;
  }

  .kb-breadcrumbs a {
    color: var(--color-secondary, #2563eb);
    text-decoration: none;
  }

  .sep { margin: 0 0.4rem; }

  .cat-header {
    margin-bottom: 2rem;
  }

  .cat-header h1 {
    margin: 0;
    font-size: 1.75rem;
  }

  .cat-icon { margin-right: 0.5rem; }

  .cat-header p {
    color: var(--color-muted, #6b7280);
    margin: 0.5rem 0 0;
  }

  .cat-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2rem;
  }

  .cat-sidebar {
    position: sticky;
    top: 80px;
    height: fit-content;
  }

  .cat-sidebar h3 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted, #6b7280);
    margin: 0 0 0.75rem;
  }

  .cat-tree {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cat-item {
    margin-bottom: 0.25rem;
  }

  .cat-item.active a {
    color: var(--color-secondary, #2563eb);
    font-weight: 600;
  }

  .cat-item a {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.65rem;
    border-radius: var(--radius-sm, 0.375rem);
    color: var(--color-text, #111827);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .cat-item a:hover {
    background: var(--color-soft-background, #f0f4ff);
  }

  .article-list ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .article-card {
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-md, 0.5rem);
    transition: all 0.2s;
  }

  .article-card:hover {
    border-color: var(--color-secondary, #2563eb);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .article-link {
    display: block;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .article-link h2 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .article-link p {
    color: var(--color-muted, #6b7280);
    font-size: 0.9rem;
    margin: 0 0 0.5rem;
  }

  .article-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.8rem;
    color: var(--color-muted, #6b7280);
  }

  .featured-badge {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    background: #fef3c7;
    color: #92400e;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .empty {
    text-align: center;
    color: var(--color-muted, #6b7280);
    padding: 3rem;
  }

  @media (max-width: 768px) {
    .cat-layout {
      grid-template-columns: 1fr;
    }

    .cat-sidebar {
      position: static;
    }
  }
</style>
