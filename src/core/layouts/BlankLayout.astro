---
// BlankLayout — no header, no footer, full viewport.
// Use for maintenance pages, coming-soon, full-screen apps, or landing pages.
import "../styles/global.css";

const {
  title = "",
  description = "",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>

  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
