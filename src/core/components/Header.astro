---
import WidgetArea from "@kapi/components/WidgetArea.astro";
import AnnouncementBar from "@kapi/components/AnnouncementBar.astro";
import TopBar from "@kapi/components/TopBar.astro";
import DesktopMenu from "@kapi/components/navigation/DesktopMenu.astro";
import MobileMenu from "@kapi/components/navigation/MobileMenu.astro";

const {
  settings,
  primaryMenu,
  mobileMenu,
  secondaryMenu,
  utilityMenu,
} = Astro.props;

const header = settings?.theme?.header || {};
const isSticky = Boolean(header.sticky);
const isTransparent = Boolean(header.transparent);
const showSearch = header.showSearch !== false;
const mobileMenuLabel = header.mobileMenuLabel || "Menu";
const showTopBar = header.showTopBar !== false;
const showCta = Boolean(header.showCta);
const ctaLabel = header.ctaLabel || "Contact";
const ctaUrl = header.ctaUrl || "/contact";

const logo = typeof settings?.logo === "string" ? null : settings?.logo;
---

<WidgetArea name="before-header">
  <AnnouncementBar />
</WidgetArea>

{showTopBar && <TopBar settings={settings} utilityMenu={utilityMenu} />}

<header class:list={["site-header", { sticky: isSticky, transparent: isTransparent }]}>
  <div class="site-header-inner">
    <a class="brand" href="/">
      {logo?.src ? (
        <img
          src={logo.src}
          alt={logo.alt || settings?.siteTitle || "KapiLabs"}
          width={logo.width}
          height={logo.height}
        />
      ) : (
        <span>{settings?.siteTitle || "KapiLabs"}</span>
      )}
    </a>

    <DesktopMenu menu={primaryMenu} currentPath={Astro.url.pathname} />

    <WidgetArea name="header-right">
      {showCta && (
        <a class="header-cta" href={ctaUrl}>
          {ctaLabel}
        </a>
      )}
    </WidgetArea>

    {showSearch && <a class="header-search" href="/search">Search</a>}

    <MobileMenu menu={mobileMenu || primaryMenu} currentPath={Astro.url.pathname} label={mobileMenuLabel} />
  </div>

  {secondaryMenu?.items?.length > 0 && (
    <div class="secondary-menu-wrap">
      <DesktopMenu menu={secondaryMenu} currentPath={Astro.url.pathname} />
    </div>
  )}
</header>

<WidgetArea name="after-header" />

<style>
  .site-header {
    background: var(--color-background);
    color: var(--color-text);
    border-bottom: 1px solid #e5e7eb;
  }

  .site-header.sticky {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .site-header-inner {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    justify-content: space-between;
  }

  .secondary-menu-wrap {
    border-top: 1px solid var(--color-border, #e5e7eb);
    background: var(--color-soft-background, #f9fafb);
  }

  .secondary-menu-wrap :global(.desktop-menu) {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0.65rem 1rem;
  }

  .brand {
    color: inherit;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.25rem;
  }

  .brand img {
    display: block;
    max-height: 48px;
    width: auto;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.65rem 1rem;
    border-radius: var(--button-radius);
    background: var(--color-secondary);
    color: white;
    text-decoration: none;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .header-cta,
    .secondary-menu-wrap {
      display: none;
    }
  }
</style>

<style>
  .site-header.transparent {
    background: transparent;
    border-bottom-color: transparent;
  }

  .header-search {
    font-weight: 700;
    text-decoration: none;
    color: inherit;
  }

  @media (max-width: 768px) {
    .header-search {
      display: none;
    }
  }
</style>
