---
import { getPosts } from "@kapi/cms";

const { title, count = 5 } = Astro.props;
const posts = (await getPosts()).slice(0, count);
---

<div class="widget widget-recent-posts">
  {title && <h3>{title}</h3>}
  <ul>
    {posts.map((post: any) => (
      <li>
        <a href={`/blog/${post.slug}`}>
          {post.featuredImage?.src && (
            <img src={post.featuredImage.src} alt="" width="60" height="60" loading="lazy" />
          )}
          <span>{post.title}</span>
        </a>
        {post.publishedAt && <small>{new Date(post.publishedAt).toLocaleDateString()}</small>}
      </li>
    ))}
  </ul>
</div>

<style>
  .widget-recent-posts ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 12px;
  }

  .widget-recent-posts li a {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    color: inherit;
    text-decoration: none;
  }

  .widget-recent-posts li a:hover {
    opacity: 0.8;
  }

  .widget-recent-posts img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: var(--radius-sm, 0.375rem);
    flex-shrink: 0;
  }

  .widget-recent-posts small {
    display: block;
    color: var(--color-muted, #6b7280);
    font-size: 0.8rem;
    margin-top: 2px;
  }
</style>
