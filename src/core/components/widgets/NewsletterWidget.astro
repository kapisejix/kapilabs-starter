---
import { isNewsletterConfigured } from "@kapi/newsletter";

const {
  title = "Newsletter",
  description = "Subscribe to our newsletter for the latest updates.",
  placeholder = "your@email.com",
  buttonLabel = "Subscribe",
} = Astro.props;

const isConfigured = isNewsletterConfigured();
---

<div class="widget widget-newsletter">
  {title && <h3>{title}</h3>}
  {description && <p class="newsletter-desc">{description}</p>}

  {isConfigured ? (
    <form class="newsletter-form" data-newsletter-form>
      <input
        type="email"
        name="email"
        placeholder={placeholder}
        required
        aria-label="Email address"
      />
      <input type="hidden" name="name" />
      <input type="hidden" name="csrfToken" value="" data-csrf-input />
      <button type="submit">{buttonLabel}</button>
      <p class="newsletter-message" data-newsletter-message></p>
    </form>
  ) : (
    <form class="newsletter-form" method="post" action="/api/forms/submit">
      <input type="hidden" name="formType" value="newsletter" />
      <input
        type="email"
        name="email"
        placeholder={placeholder}
        required
        aria-label="Email address"
      />
      <button type="submit">{buttonLabel}</button>
    </form>
  )}
</div>

<script>
  // Fetch CSRF token before first use
  async function fetchCsrfToken(): Promise<string | null> {
    try {
      const response = await fetch("/api/newsletter/csrf-token", {
        method: "GET",
        credentials: "same-origin",
      });
      if (!response.ok) return null;
      const data = await response.json();
      return data.csrfToken || null;
    } catch {
      return null;
    }
  }

  // Client-side handler for newsletter provider subscription
  document.querySelectorAll<HTMLFormElement>("[data-newsletter-form]").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const message = form.querySelector<HTMLElement>("[data-newsletter-message]");
      const button = form.querySelector<HTMLButtonElement>("button[type='submit']");
      const emailInput = form.querySelector<HTMLInputElement>("input[name='email']");

      if (!message || !button || !emailInput) return;

      const email = emailInput.value.trim();

      if (!email) {
        message.textContent = "Please enter your email address.";
        return;
      }

      button.disabled = true;
      message.textContent = "Subscribing...";

      // Fetch CSRF token and set cookie before subscribing
      const csrfToken = await fetchCsrfToken();
      if (!csrfToken) {
        message.textContent = "Unable to start request. Please refresh and try again.";
        button.disabled = false;
        return;
      }

      try {
        const response = await fetch("/api/newsletter/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ email, csrfToken }),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.message || "Subscription failed.");
        }

        form.reset();
        message.textContent = "Thank you for subscribing!";
      } catch (error: unknown) {
        message.textContent =
          error instanceof Error ? error.message : "Something went wrong.";
      } finally {
        button.disabled = false;
      }
    });
  });
</script>

<style>
  .widget-newsletter {
    display: grid;
    gap: 12px;
  }

  .newsletter-desc {
    color: var(--color-muted, #6b7280);
    font-size: 0.9rem;
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .newsletter-form input[type="email"] {
    flex: 1;
    min-width: 150px;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-sm, 0.375rem);
    font-size: 0.9rem;
  }

  .newsletter-form button {
    padding: 0.6rem 1rem;
    border: none;
    border-radius: var(--radius-sm, 0.375rem);
    background: var(--color-primary, #111827);
    color: white;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }

  .newsletter-form button:hover {
    opacity: 0.9;
  }

  .newsletter-form button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter-message {
    width: 100%;
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-muted, #6b7280);
  }
</style>
