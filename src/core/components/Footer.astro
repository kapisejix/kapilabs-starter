---
import WidgetArea from "@kapi/components/WidgetArea.astro";

const { settings, menu } = Astro.props;

const year = new Date().getFullYear();

const footer = settings?.theme?.footer || {};
const showFooterWidgets = footer.showFooterWidgets !== false;
const copyrightText =
  footer.copyrightText ||
  `© ${year} ${settings?.siteTitle || "KapiLabs"}. All rights reserved.`;
---

<footer class="site-footer">
  {showFooterWidgets && (
    <div class="site-container footer-widgets">
      <WidgetArea name="footer-1">
        <div>
          <h2>{settings?.siteTitle}</h2>
          {settings?.tagline && <p>{settings.tagline}</p>}
          {settings?.address && <p>{settings.address}</p>}
        </div>
      </WidgetArea>

      <WidgetArea name="footer-2">
        <nav aria-label="Footer navigation">
          <h3>Links</h3>
          {menu?.items?.map((item: any) => (
            <a
              href={item.url}
              target={item.targetBlank ? "_blank" : undefined}
              rel={item.targetBlank ? "noopener noreferrer" : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </WidgetArea>

      <WidgetArea name="footer-3">
        <div>
          <h3>Contact</h3>
          {settings?.phone && <p>{settings.phone}</p>}
          {settings?.email && <p>{settings.email}</p>}
        </div>
      </WidgetArea>
    </div>
  )}

  <div class="site-container copyright">
    {copyrightText}
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary);
    color: white;
    padding: 48px 0 24px;
    margin-top: 48px;
  }

  .footer-widgets {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .site-footer p,
  .site-footer a {
    color: #d1d5db;
  }

  .site-footer nav {
    display: grid;
    gap: 10px;
  }

  .copyright {
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    margin-top: 32px;
    padding-top: 24px;
    color: #d1d5db;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .footer-widgets {
      grid-template-columns: 1fr;
    }
  }
</style>
