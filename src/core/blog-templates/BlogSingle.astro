---
import ContentBody from "@kapi/components/content/ContentBody.astro";
import PageBanner from "@kapi/sections/PageBanner.astro";
import RelatedContent from "@kapi/components/RelatedContent.astro";
import AuthorBox from "@kapi/components/AuthorBox.astro";

const { post, relatedPosts = [] } = Astro.props;
---

<article class="blog-single">
  <PageBanner banner={post.banner} />

  <header class="blog-header">
    {!post.banner?.heading && <h1>{post.title}</h1>}

    {post.publishedAt && (
      <p class="blog-date">
        {new Date(post.publishedAt).toLocaleDateString()}
      </p>
    )}

    {post.excerpt && <p class="blog-excerpt">{post.excerpt}</p>}

    {post.categories?.length > 0 && (
      <p class="blog-meta">
        Categories: {post.categories.join(", ")}
      </p>
    )}

    {post.tags?.length > 0 && (
      <p class="blog-meta">
        Tags: {post.tags.join(", ")}
      </p>
    )}
  </header>

  {post.content && <ContentBody content={post.content} />}

  <AuthorBox author={post.author} />

  <RelatedContent items={relatedPosts} title="Related Posts" />
</article>

<style>
  .blog-single {
    max-width: var(--content-width, 860px);
    margin: 0 auto;
    padding: var(--space-xl, 3rem) 1rem;
    display: grid;
    gap: var(--space-lg, 2rem);
  }

  .blog-header {
    display: grid;
    gap: 0.5rem;
  }

  .blog-date,
  .blog-meta {
    color: var(--color-muted);
    margin: 0;
  }

  .blog-excerpt {
    font-size: 1.2rem;
    color: var(--color-muted);
    margin: 0;
  }
</style>
