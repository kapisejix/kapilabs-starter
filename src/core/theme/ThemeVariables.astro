---
const { settings } = Astro.props;

const theme = settings?.theme || {};
const typography = theme.typography || {};
const tokens = theme.tokens || {};

const colors = tokens.colors || {};
const darkColors = tokens.dark || {};
const spacing = tokens.spacing || {};
const radius = tokens.radius || {};
const breakpoints = tokens.breakpoints || {};

const buttonRadius =
  theme.buttonStyle === "pill"
    ? "999px"
    : theme.buttonStyle === "square"
      ? "0px"
      : radius.md || "0.5rem";

// Typography scale helpers
const baseSize = typography.baseSize || "16px";
const scale = typography.scale || "1.25";
const lineHeight = typography.lineHeight || "1.6";
const headingLineHeight = typography.headingLineHeight || "1.2";
const letterSpacing = typography.letterSpacing || "0";
const fontWeight = typography.fontWeight || "400";
const headingFontWeight = typography.headingFontWeight || "700";
---

<style is:global define:vars={{
  // ── Colors ──
  primaryColor: colors.primary || theme.primaryColor || "#111827",
  secondaryColor: colors.secondary || theme.secondaryColor || "#2563eb",
  backgroundColor: colors.background || theme.backgroundColor || "#ffffff",
  textColor: colors.text || theme.textColor || "#111827",
  mutedColor: colors.muted || "#6b7280",
  borderColor: colors.border || "#e5e7eb",
  softBackgroundColor: colors.softBackground || "#f9fafb",
  accentColor: colors.accent || "#f59e0b",
  surfaceColor: colors.surface || "#ffffff",
  linkColor: colors.link || colors.secondary || theme.secondaryColor || "#2563eb",
  buttonColor: colors.button || colors.primary || theme.primaryColor || "#111827",

  // ── Dark mode colors ──
  darkPrimaryColor: darkColors.primary || "#ffffff",
  darkSecondaryColor: darkColors.secondary || "#93c5fd",
  darkBackgroundColor: darkColors.background || "#0f172a",
  darkTextColor: darkColors.text || "#e2e8f0",
  darkMutedColor: darkColors.muted || "#94a3b8",
  darkBorderColor: darkColors.border || "#1e293b",
  darkSurfaceColor: darkColors.surface || "#1e293b",

  // ── Typography ──
  fontFamily: typography.fontFamily || "system-ui, sans-serif",
  headingFontFamily: typography.headingFontFamily || typography.fontFamily || "system-ui, sans-serif",
  baseFontSize: baseSize,
  typeScale: scale,
  bodyLineHeight: lineHeight,
  headingLineHeightValue: headingLineHeight,
  letterSpacingValue: letterSpacing,
  bodyFontWeight: fontWeight,
  headingFontWeightValue: headingFontWeight,

  // ── Spacing ──
  spacingXs: spacing.xs || "0.5rem",
  spacingSm: spacing.sm || "1rem",
  spacingMd: spacing.md || "1.5rem",
  spacingLg: spacing.lg || "2rem",
  spacingXl: spacing.xl || "3rem",
  spacing2xl: spacing.xxl || "4rem",

  // ── Radius ──
  radiusSm: radius.sm || "0.375rem",
  radiusMd: radius.md || "0.5rem",
  radiusLg: radius.lg || "1rem",
  radiusFull: radius.full || "999px",

  // ── Layout ──
  containerWidth: theme.containerWidth || tokens.containerWidth || "1200px",
  breakpointSm: breakpoints.sm || "640px",
  breakpointMd: breakpoints.md || "768px",
  breakpointLg: breakpoints.lg || "1024px",
  breakpointXl: breakpoints.xl || "1280px",

  buttonRadius,
}}>
  :root {
    /* ── Colors ── */
    --color-primary: var(--primaryColor);
    --color-secondary: var(--secondaryColor);
    --color-background: var(--backgroundColor);
    --color-text: var(--textColor);
    --color-muted: var(--mutedColor);
    --color-border: var(--borderColor);
    --color-soft-background: var(--softBackgroundColor);
    --color-accent: var(--accentColor);
    --color-surface: var(--surfaceColor);
    --color-link: var(--linkColor);
    --color-button: var(--buttonColor);

    /* ── Dark mode tokens ── */
    --dark-primary: var(--darkPrimaryColor);
    --dark-secondary: var(--darkSecondaryColor);
    --dark-background: var(--darkBackgroundColor);
    --dark-text: var(--darkTextColor);
    --dark-muted: var(--darkMutedColor);
    --dark-border: var(--darkBorderColor);
    --dark-surface: var(--darkSurfaceColor);

    /* ── Typography ── */
    --font-body: var(--fontFamily);
    --font-heading: var(--headingFontFamily);
    --font-size-base: var(--baseFontSize);
    --type-scale: var(--typeScale);
    --line-height: var(--bodyLineHeight);
    --heading-line-height: var(--headingLineHeightValue);
    --letter-spacing: var(--letterSpacingValue);
    --font-weight-body: var(--bodyFontWeight);
    --font-weight-heading: var(--headingFontWeightValue);

    /* ── Spacing ── */
    --space-xs: var(--spacingXs);
    --space-sm: var(--spacingSm);
    --space-md: var(--spacingMd);
    --space-lg: var(--spacingLg);
    --space-xl: var(--spacingXl);
    --space-2xl: var(--spacing2xl);

    /* ── Radius ── */
    --radius-sm: var(--radiusSm);
    --radius-md: var(--radiusMd);
    --radius-lg: var(--radiusLg);
    --radius-full: var(--radiusFull);

    /* ── Layout ── */
    --container-width: var(--containerWidth);
    --site-width: var(--containerWidth);
    --sidebar-width: var(--sidebarWidth, 320px);
    --gap: var(--spacingMd);

    /* ── Breakpoints ── */
    --breakpoint-sm: var(--breakpointSm);
    --breakpoint-md: var(--breakpointMd);
    --breakpoint-lg: var(--breakpointLg);
    --breakpoint-xl: var(--breakpointXl);

    /* ── Utils ── */
    --button-radius: var(--buttonRadius);
    --border: var(--color-border);
    --text: var(--color-text);
    --muted: var(--color-muted);
    --bg: var(--color-background);
    --soft-bg: var(--color-soft-background);
    --accent: var(--color-accent);
    --surface: var(--color-surface);
    --link: var(--color-link);
  }

  body {
    background: var(--color-background);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    line-height: var(--line-height);
    font-weight: var(--font-weight-body);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    line-height: var(--heading-line-height);
    font-weight: var(--font-weight-heading);
  }

  a {
    color: var(--color-link);
  }

  /* ── Dark mode via class on <html> ── */
  html.dark,
  html[data-theme="dark"] {
    --color-primary: var(--dark-primary);
    --color-secondary: var(--dark-secondary);
    --color-background: var(--dark-background);
    --color-text: var(--dark-text);
    --color-muted: var(--dark-muted);
    --color-border: var(--dark-border);
    --color-surface: var(--dark-surface);
    --color-soft-background: var(--dark-surface);

    --bg: var(--dark-background);
    --text: var(--dark-text);
    --muted: var(--dark-muted);
    --border: var(--dark-border);
    --surface: var(--dark-surface);
    --soft-bg: var(--dark-surface);
  }

  /* ── System preference dark mode (opt-in) ── */
  @media (prefers-color-scheme: dark) {
    html[data-theme="system"] {
      --color-primary: var(--dark-primary);
      --color-secondary: var(--dark-secondary);
      --color-background: var(--dark-background);
      --color-text: var(--dark-text);
      --color-muted: var(--dark-muted);
      --color-border: var(--dark-border);
      --color-surface: var(--dark-surface);
      --color-soft-background: var(--dark-surface);

      --bg: var(--dark-background);
      --text: var(--dark-text);
      --muted: var(--dark-muted);
      --border: var(--dark-border);
      --surface: var(--dark-surface);
      --soft-bg: var(--dark-surface);
    }
  }
</style>
