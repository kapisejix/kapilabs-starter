---
const { section } = Astro.props;
const settings = section.settings || {};
const align = settings.alignment || "center";
const btnStyle = settings.buttonStyle || "solid";
---

<section class:list={["section cta-section", `cta-align-${align}`, `btn-style-${btnStyle}`]}>
  <h2>{section.heading}</h2>
  {section.text && <Fragment set:html={section.text} />}

  {section.buttonLabel && section.buttonUrl && (
    <a class="button" href={section.buttonUrl}>{section.buttonLabel}</a>
  )}
</section>

<style>
  .cta-section {
    display: grid;
    gap: 20px;
    border-radius: var(--section-radius, 20px);
    padding: var(--section-padding, 40px);
    background: var(--section-bg, var(--color-soft-background, #f9fafb));
    text-align: var(--section-align, center);
  }

  .cta-section h2 {
    margin: 0;
  }

  .cta-align-left {
    text-align: left;
  }

  .cta-align-center {
    text-align: center;
  }

  .cta-align-right {
    text-align: right;
    justify-items: end;
  }

  .button {
    display: inline-flex;
    justify-self: center;
    width: fit-content;
    border-radius: var(--button-radius, 999px);
    padding: 12px 24px;
    font-weight: 800;
    background: var(--color-button, #111827);
    color: #fff;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .button:hover {
    opacity: 0.85;
  }

  .cta-align-left .button {
    justify-self: start;
  }

  .cta-align-right .button {
    justify-self: end;
  }

  .btn-style-outline .button {
    background: transparent;
    border: 2px solid var(--color-button, #111827);
    color: var(--color-button, #111827);
  }

  .btn-style-ghost .button {
    background: transparent;
    border: none;
    color: var(--color-link, #2563eb);
    padding: 12px 0;
  }
</style>


