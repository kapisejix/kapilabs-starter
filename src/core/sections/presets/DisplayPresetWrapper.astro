---
import type { DisplayPreset, SectionSettings } from "@kapi/cms/types";
import { presetCssClass } from "@kapi/sections/sectionSettings";

export type Props = {
  items?: any[];
  preset?: DisplayPreset;
  settings?: SectionSettings;
  heading?: string;
};

const { items = [], preset, settings } = Astro.props;
const wrapperClass = presetCssClass(preset);
---

{preset === "carousel" && (
  <div class:list={["display-preset", wrapperClass, "carousel-track"]}>
    <slot />
  </div>
)}

{preset === "masonry" && (
  <div class:list={["display-preset", wrapperClass]}>
    <slot />
  </div>
)}

{preset === "tabs" && (
  <div class:list={["display-preset", wrapperClass]} data-tabs>
    {items.length > 0 && (
      <div class="tabs-nav" role="tablist">
        {items.map((item: any, i: number) => (
          <button
            role="tab"
            class:list={["tab-btn", i === 0 && "active"]}
            aria-selected={i === 0}
            data-tab-index={i}
          >
            {item.title || item.heading || item.label || `Tab ${i + 1}`}
          </button>
        ))}
      </div>
    )}
    <div class="tab-panel active" role="tabpanel" data-tab-index={0}>
      <slot />
    </div>
  </div>
)}

{preset === "accordion" && (
  <div class:list={["display-preset", wrapperClass]} data-accordion>
    <slot />
  </div>
)}

{preset === "timeline" && (
  <div class:list={["display-preset", wrapperClass]}>
    <slot />
  </div>
)}

{preset === "list" && (
  <div class:list={["display-preset", wrapperClass]}>
    <slot />
  </div>
)}

{preset === "slider" && (
  <div class:list={["display-preset", wrapperClass, "slider-track"]}>
    <slot />
  </div>
)}

{preset === "scroll" && (
  <div class:list={["display-preset", wrapperClass, "scroll-row"]}>
    <slot />
  </div>
)}

{preset === "stack" && (
  <div class:list={["display-preset", wrapperClass]}>
    <slot />
  </div>
)}

{(!preset || preset === "grid" || preset === "cards" || preset === "minimal") && (
  <div class:list={["display-preset", wrapperClass]}>
    <slot />
  </div>
)}

<style is:global>
  /* ── Base Display Preset Styles ── */

  /* Grid (default) */
  .display-preset.preset-grid,
  .display-preset.preset-cards,
  .display-preset.preset-minimal {
    display: grid;
    grid-template-columns: var(--section-columns, 3);
    gap: var(--section-gap, 1.5rem);
  }

  .display-preset.preset-grid {
    grid-template-columns: repeat(var(--section-columns, 3), 1fr);
  }

  .display-preset.preset-cards {
    grid-template-columns: repeat(var(--section-columns, 3), 1fr);
  }

  .display-preset.preset-cards .preset-item {
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--section-radius, 0.75rem);
    padding: 1.5rem;
    background: var(--color-surface, #ffffff);
    box-shadow: var(--section-shadow, none);
  }

  .display-preset.preset-minimal .preset-item {
    padding: 1rem 0;
  }

  /* List */
  .display-preset.preset-list {
    display: flex;
    flex-direction: column;
    gap: var(--section-gap, 1rem);
  }

  .display-preset.preset-list .preset-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .display-preset.preset-list .preset-item:last-child {
    border-bottom: none;
  }

  /* Carousel */
  .display-preset.preset-carousel.carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    gap: var(--section-gap, 1rem);
    padding-bottom: 0.5rem;
  }

  .display-preset.preset-carousel .preset-item {
    flex: 0 0 calc((100% - (var(--section-columns, 3) - 1) * var(--section-gap, 1rem)) / var(--section-columns, 3));
    min-width: 280px;
    scroll-snap-align: start;
  }

  .display-preset.preset-carousel .preset-item:last-child {
    scroll-snap-align: end;
  }

  /* Masonry */
  .display-preset.preset-masonry {
    columns: var(--section-columns, 3);
    column-gap: var(--section-gap, 1.5rem);
  }

  .display-preset.preset-masonry .preset-item {
    break-inside: avoid;
    margin-bottom: var(--section-gap, 1.5rem);
  }

  /* Tabs */
  .display-preset.preset-tabs {
    display: grid;
    gap: 1rem;
  }

  .display-preset.preset-tabs .tabs-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    border-bottom: 2px solid var(--color-border, #e5e7eb);
    padding-bottom: 0.5rem;
  }

  .display-preset.preset-tabs .tab-btn {
    padding: 0.5rem 1.25rem;
    border: none;
    background: none;
    cursor: pointer;
    font-weight: 600;
    color: var(--color-muted, #6b7280);
    border-radius: var(--radius-sm, 0.375rem);
    transition: color 0.2s, background 0.2s;
  }

  .display-preset.preset-tabs .tab-btn:hover {
    color: var(--color-text, #111827);
    background: var(--color-soft-background, #f9fafb);
  }

  .display-preset.preset-tabs .tab-btn.active,
  .display-preset.preset-tabs .tab-btn[aria-selected="true"] {
    color: var(--color-primary, #111827);
    background: var(--color-soft-background, #f9fafb);
    font-weight: 700;
  }

  /* Accordion */
  .display-preset.preset-accordion {
    display: grid;
    gap: 0.75rem;
  }

  .display-preset.preset-accordion .accordion-item {
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-md, 0.5rem);
    overflow: hidden;
    background: var(--color-surface, #ffffff);
  }

  .display-preset.preset-accordion .accordion-header {
    padding: 1rem 1.25rem;
    cursor: pointer;
    font-weight: 700;
    font-size: 1.05rem;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .display-preset.preset-accordion .accordion-header::-webkit-details-marker {
    display: none;
  }

  .display-preset.preset-accordion .accordion-header::after {
    content: "+";
    font-size: 1.25rem;
    transition: transform 0.2s;
  }

  .display-preset.preset-accordion details[open] .accordion-header::after {
    content: "−";
  }

  .display-preset.preset-accordion .accordion-body {
    padding: 0 1.25rem 1.25rem;
    color: var(--color-muted, #6b7280);
  }

  /* Timeline */
  .display-preset.preset-timeline {
    display: grid;
    gap: 0;
    position: relative;
  }

  .display-preset.preset-timeline::before {
    content: "";
    position: absolute;
    left: 11px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border, #e5e7eb);
  }

  .display-preset.preset-timeline .timeline-item {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 1rem;
    padding: 1rem 0;
    position: relative;
  }

  .display-preset.preset-timeline .timeline-marker {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-primary, #111827);
    border: 2px solid var(--color-surface, #ffffff);
    margin-top: 4px;
    z-index: 1;
  }

  .display-preset.preset-timeline .timeline-title {
    margin: 0 0 0.25rem;
  }

  /* Slider */
  .display-preset.preset-slider.slider-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
  }

  .display-preset.preset-slider .slider-slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
  }

  /* Scroll row */
  .display-preset.preset-scroll.scroll-row {
    display: flex;
    overflow-x: auto;
    gap: var(--section-gap, 1rem);
    padding-bottom: 0.5rem;
    -webkit-overflow-scrolling: touch;
  }

  .display-preset.preset-scroll .scroll-item {
    flex: 0 0 300px;
  }

  /* Stack */
  .display-preset.preset-stack {
    display: grid;
    gap: 0;
  }

  .display-preset.preset-stack .stack-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .display-preset.preset-stack .stack-item:last-child {
    border-bottom: none;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .display-preset.preset-grid,
    .display-preset.preset-cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .display-preset.preset-masonry {
      columns: 2;
    }

    .display-preset.preset-carousel .preset-item {
      flex: 0 0 85%;
    }
  }

  @media (max-width: 560px) {
    .display-preset.preset-grid,
    .display-preset.preset-cards,
    .display-preset.preset-masonry {
      grid-template-columns: 1fr;
      columns: 1;
    }

    .display-preset.preset-tabs .tabs-nav {
      flex-direction: column;
    }
  }
</style>

<script>
  // Minimal JS for tab switching (client island)
  document.querySelectorAll("[data-tabs]").forEach((tabsEl) => {
    const buttons = tabsEl.querySelectorAll<HTMLButtonElement>(".tab-btn");
    const panels = tabsEl.querySelectorAll<HTMLElement>(".tab-panel");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = parseInt(btn.dataset.tabIndex || "0");

        buttons.forEach((b) => {
          b.classList.remove("active");
          b.setAttribute("aria-selected", "false");
        });
        panels.forEach((p) => {
          p.classList.remove("active");
          p.hidden = true;
        });

        btn.classList.add("active");
        btn.setAttribute("aria-selected", "true");
        panels[idx].classList.add("active");
        panels[idx].hidden = false;
      });
    });
  });
</script>
