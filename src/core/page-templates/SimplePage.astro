---
import PageBanner from "@kapi/sections/PageBanner.astro";
import ContentBody from "@kapi/components/content/ContentBody.astro";

const { page } = Astro.props;
---

<article class="page-template page-template-simple">
  <PageBanner banner={page.banner} />

  {!page.banner?.heading && <h1>{page.title}</h1>}

  <div class="card">
    <ContentBody content={page.content} />
  </div>
</article>
